# GHL LeadConnector webhooks
VITE_WEBHOOK_REGISTRO=
VITE_WEBHOOK_CALIFICACION=

# NOTE — Meta Conversions API secrets NO van aquí.
# Token y Pixel ID se manejan como Cloudflare Worker secrets:
#   wrangler secret put META_PIXEL_ID
#   wrangler secret put META_ACCESS_TOKEN
#   wrangler secret put META_TEST_EVENT_CODE   (solo para QA, borrar antes de producción)
#
# Para dev local del Worker, crear .dev.vars (gitignored) con:
#   META_PIXEL_ID=...
#   META_ACCESS_TOKEN=...
#   META_TEST_EVENT_CODE=...
